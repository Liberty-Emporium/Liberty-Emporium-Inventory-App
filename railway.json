{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "gunicorn app_with_ai:app --bind 0.0.0.0:$PORT --workers 1 --timeout 300 --log-level info",
    "volume": "/data"
  }
}
