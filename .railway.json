{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "buildCommand": "pip install -r requirements.txt",
    "startCommand": "python -m gunicorn app_with_ai:app --bind 0.0.0.0:$PORT --timeout 180 --workers 1"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ALWAYS"
  },
  "volumes": [
    {
      "name": "data",
      "path": "/data",
      "size": "10GB"
    }
  ],
  "env": {
    "RAILWAY_DATA_DIR": "/data"
  }
}
